{
  "datasets": [
    {
      "name": "1ad388a6",
      "displayName": "Gold Stock Market Snapshot Latest Trading Data",
      "queryLines": [
        "SELECT \r\n",
        "    ticker,\r\n",
        "    current_price,\r\n",
        "    change_pct,\r\n",
        "    market_status,\r\n",
        "    price_change_category,\r\n",
        "    volume_category,\r\n",
        "    CAST(volume AS DOUBLE) as volume,\r\n",
        "    volatility,\r\n",
        "    price_range_pct,\r\n",
        "    trade_date,\r\n",
        "    timestamp\r\n",
        "FROM stockmarket.stockmarket_db.gold_stocks\r\n",
        "WHERE trade_date = (\r\n",
        "    SELECT MAX(trade_date) \r\n",
        "    FROM stockmarket.stockmarket_db.gold_stocks\r\n",
        ")\r\n",
        "ORDER BY current_price DESC"
      ],
      "catalog": "stockmarket",
      "schema": "stockmarket_db"
    },
    {
      "name": "c28b81e3",
      "displayName": "counter no of stocks latest",
      "queryLines": [
        "SELECT\r\n",
        "  *\r\n",
        "FROM\r\n",
        "  stockmarket.stockmarket_db.gold_stocks\r\n",
        "WHERE\r\n",
        "  trade_date\r\n",
        "    = (\r\n",
        "      SELECT\r\n",
        "        MAX(trade_date)\r\n",
        "      FROM\r\n",
        "        stockmarket.stockmarket_db.gold_stocks\r\n",
        "    )"
      ]
    },
    {
      "name": "8e75d0d0",
      "displayName": "Counter per stock: MSFT",
      "queryLines": [
        "SELECT current_price\r\n",
        "FROM stockmarket.stockmarket_db.gold_stocks\r\n",
        "WHERE ticker = 'MSFT'\r\n",
        "AND trade_date = (\r\n",
        "    SELECT MAX(trade_date)\r\n",
        "    FROM stockmarket.stockmarket_db.gold_stocks\r\n",
        ")"
      ]
    },
    {
